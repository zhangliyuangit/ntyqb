<view class="page record-page tab-page">
  <view wx:if="{{loading}}" class="empty">正在整理比赛记录…</view>

  <block wx:elif="{{!loggedIn}}">
    <view class="card auth-gate-card section">
      <view class="section-kicker">比赛记录</view>
      <view class="section-title">先看看功能，再决定要不要登录</view>
      <view class="gate-copy">登录后可以发起比赛记录、查看待你确认的球局，以及管理你发起过的比赛流程。</view>
      <view class="gate-feature-list">
        <view class="gate-feature">发起比赛并邀请对手确认</view>
        <view class="gate-feature">查看“待我确认”和“我发起的”记录</view>
        <view class="gate-feature">快速复用最近对手和队友</view>
      </view>
      <button class="button-primary gate-login-btn" bindtap="onLoginTap">登录后开始记录</button>
    </view>
  </block>

  <block wx:else>
    <view wx:if="{{refreshing}}" class="page-refresh-indicator section">记录同步中...</view>

    <view class="page-stage {{refreshing ? 'is-refreshing' : 'is-settled'}}">
      <view class="list-toolbar section">
        <view class="section-title">比赛记录</view>
      </view>

      <view class="step-card section filter-card">
        <view class="section-head">
          <view>
            <view class="section-title">筛选条件</view>
          </view>
        </view>
        <view class="pill-tabs">
          <view class="pill-tab {{listScope === 'mine' ? 'active' : ''}}" data-scope="mine" bindtap="onScopeTap">我的全部</view>
          <view class="pill-tab {{listScope === 'pending_confirmation' ? 'active' : ''}}" data-scope="pending_confirmation" bindtap="onScopeTap">待我确认</view>
          <view class="pill-tab {{listScope === 'initiated' ? 'active' : ''}}" data-scope="initiated" bindtap="onScopeTap">我发起的</view>
        </view>
        <view class="pill-tabs status-tabs">
          <view class="pill-tab {{listStatus === 'PENDING' ? 'active' : ''}}" data-status="PENDING" bindtap="onStatusTap">待确认</view>
          <view class="pill-tab {{listStatus === 'CONFIRMED' ? 'active' : ''}}" data-status="CONFIRMED" bindtap="onStatusTap">已生效</view>
          <view class="pill-tab {{listStatus === 'REJECTED' ? 'active' : ''}}" data-status="REJECTED" bindtap="onStatusTap">被拒绝</view>
        </view>
        <view wx:if="{{pendingConfirmationCount > 0 && listScope === 'pending_confirmation'}}" class="filter-tip">
          你有 {{pendingConfirmationCount}} 场比赛待确认，已优先切到“待我确认”。
        </view>
      </view>

      <view wx:if="{{matches.length === 0}}" class="card empty">暂时没有符合条件的记录</view>
      <match-card
        wx:for="{{matches}}"
        wx:key="id"
        match="{{item}}"
        bindconfirm="onMatchConfirm"
        bindreject="onMatchReject"
        bindcancel="onMatchCancel"
      />
    </view>
  </block>

  <view wx:if="{{createOverlayVisible}}" class="create-overlay" catchtouchmove="noop">
    <view class="create-overlay-mask" bindtap="closeCreateOverlay"></view>
    <view class="create-sheet" catchtap="noop">
      <view class="create-sheet-handle"></view>
      <view class="create-sheet-head">
        <view>
          <view class="section-kicker">新增记录</view>
        </view>
        <view class="sheet-close" bindtap="closeCreateOverlay">关闭</view>
      </view>

      <scroll-view scroll-y class="create-sheet-body">
        <view class="workflow-strip section">
          <view class="workflow-step ready">1 选球类</view>
          <view class="workflow-step {{teamB.length > 0 ? 'ready' : ''}}">2 选参赛者</view>
          <view class="workflow-step {{activeSport === 'BILLIARDS' ? (winMarginBalls !== '' ? 'ready' : '') : (sets[0].aScore !== '' && sets[0].bScore !== '' ? 'ready' : '')}}">3 填比分</view>
        </view>

        <view class="step-card section">
          <view class="step-head">
            <view>
              <view class="step-index">STEP 1</view>
              <view class="section-title">选择球类和结果</view>
            </view>
            <view class="step-note">{{activeSport === 'BILLIARDS' ? '台球 1v1' : activeSport === 'TABLE_TENNIS' ? '乒乓球 1v1' : format === 'DOUBLES' ? '羽毛球双打' : '羽毛球单打'}}</view>
          </view>
          <view class="pill-tabs">
            <view wx:for="{{sportOptions}}" wx:key="value" class="pill-tab {{activeSport === item.value ? 'active' : ''}}" data-sport-type="{{item.value}}" bindtap="onSportTap">{{item.label}}</view>
          </view>

          <view wx:if="{{activeSport === 'BADMINTON'}}" class="sub-block">
            <view class="sub-title">赛制</view>
            <view class="pill-tabs">
              <view class="pill-tab {{format === 'SINGLES' ? 'active' : ''}}" data-format="SINGLES" bindtap="onFormatTap">单打</view>
              <view class="pill-tab {{format === 'DOUBLES' ? 'active' : ''}}" data-format="DOUBLES" bindtap="onFormatTap">双打</view>
            </view>
          </view>

          <view class="sub-block">
            <view class="sub-title">胜方</view>
            <view class="pill-tabs">
              <view class="pill-tab {{winnerSide === 'A' ? 'active' : ''}}" data-side="A" bindtap="onWinnerTap">我方胜</view>
              <view class="pill-tab {{winnerSide === 'B' ? 'active' : ''}}" data-side="B" bindtap="onWinnerTap">对方胜</view>
            </view>
          </view>
        </view>

        <view class="step-card section">
          <view class="step-head">
            <view>
              <view class="step-index">STEP 2</view>
              <view class="section-title">选择参赛者</view>
            </view>
            <view class="step-note">{{teamA.length}} : {{teamB.length}}</view>
          </view>
          <view class="versus-picker">
            <view class="side-panel">
              <view class="side-title">我方</view>
              <view class="side-slots">
                <view wx:for="{{teamA}}" wx:key="id" class="player-pill">
                  <image wx:if="{{item.avatarUrl}}" class="player-pill-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
                  <view wx:else class="player-pill-avatar placeholder-avatar small-avatar">球</view>
                  <view class="player-pill-main">
                    <text class="player-pill-name">{{item.nickname}}</text>
                    <text wx:if="{{item.tag}}" class="user-tag-badge small">{{item.tag}}</text>
                  </view>
                  <text wx:if="{{item.id !== myUser.id}}" class="player-pill-remove" data-team="teamA" data-user-id="{{item.id}}" bindtap="removePlayer">×</text>
                </view>
                <view wx:if="{{activeSport === 'BADMINTON' && format === 'DOUBLES' && teamA.length < 2}}" class="empty-slot">补一个搭档</view>
              </view>
            </view>
            <view class="versus-mark">VS</view>
            <view class="side-panel opponent">
              <view class="side-title">对方</view>
              <view class="side-slots">
                <view wx:for="{{teamB}}" wx:key="id" class="player-pill">
                  <image wx:if="{{item.avatarUrl}}" class="player-pill-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
                  <view wx:else class="player-pill-avatar placeholder-avatar small-avatar">球</view>
                  <view class="player-pill-main">
                    <text class="player-pill-name">{{item.nickname}}</text>
                    <text wx:if="{{item.tag}}" class="user-tag-badge small">{{item.tag}}</text>
                  </view>
                  <text class="player-pill-remove" data-team="teamB" data-user-id="{{item.id}}" bindtap="removePlayer">×</text>
                </view>
                <view wx:if="{{teamB.length === 0}}" class="empty-slot">选择对手</view>
                <view wx:elif="{{activeSport === 'BADMINTON' && format === 'DOUBLES' && teamB.length < 2}}" class="empty-slot">补齐对方队友</view>
              </view>
            </view>
          </view>

          <view class="player-search-box">
            <input class="search-input" placeholder="搜索球友昵称" placeholder-class="field-placeholder" value="{{searchKeyword}}" data-field="searchKeyword" bindinput="onInput" confirm-type="search" bindconfirm="onSearchConfirm" />
            <view class="player-search-action" bindtap="onSearchConfirm">搜索</view>
          </view>

          <view wx:if="{{searchResults.length > 0}}" class="player-results">
            <view class="player-results-head">搜索结果 · {{searchResults.length}} 人</view>
            <scroll-view scroll-y class="player-results-scroll">
              <view wx:for="{{searchResults}}" wx:key="id" class="player-row" data-player-id="{{item.id}}" bindtap="chooseSearchResult">
                <view class="player-row-user">
                  <image wx:if="{{item.avatarUrl}}" class="player-row-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
                  <view wx:else class="player-row-avatar placeholder-avatar">球</view>
                  <view class="player-row-main">
                    <view class="player-row-name">
                      <text>{{item.nickname}}</text>
                      <text wx:if="{{item.tag}}" class="user-tag-badge small">{{item.tag}}</text>
                    </view>
                    <text class="player-row-meta">点一下加入当前空位</text>
                  </view>
                </view>
                <text class="player-row-action">选择</text>
              </view>
            </scroll-view>
          </view>

          <view wx:elif="{{availablePlayers.length > 0}}" class="player-results">
            <view class="player-results-head">球友列表 · {{availablePlayers.length}} 人</view>
            <scroll-view scroll-y class="player-results-scroll">
              <view wx:for="{{availablePlayers}}" wx:key="id" class="player-row" data-player-id="{{item.id}}" bindtap="chooseAvailablePlayer">
                <view class="player-row-user">
                  <image wx:if="{{item.avatarUrl}}" class="player-row-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
                  <view wx:else class="player-row-avatar placeholder-avatar">球</view>
                  <view class="player-row-main">
                    <view class="player-row-name">
                      <text>{{item.nickname}}</text>
                      <text wx:if="{{item.tag}}" class="user-tag-badge small">{{item.tag}}</text>
                    </view>
                    <text class="player-row-meta">{{activeSport === 'BADMINTON' && format === 'DOUBLES' ? '先补我方，再补对方' : '将添加为对手'}}</text>
                  </view>
                </view>
                <text class="player-row-action">选择</text>
              </view>
            </scroll-view>
          </view>
        </view>

        <view class="step-card section sheet-tail-space">
          <view class="step-head">
            <view>
              <view class="step-index">STEP 3</view>
              <view class="section-title">填写比分</view>
            </view>
            <view class="step-note">{{activeSport === 'BILLIARDS' ? '净胜球' : activeSport === 'TABLE_TENNIS' ? '逐局录入' : '比分录入'}}</view>
          </view>

          <view wx:if="{{activeSport === 'BILLIARDS'}}" class="field">
            <view class="label">净胜球数（可填 0）</view>
            <input class="input" type="number" cursor-spacing="24" placeholder="填净胜球，如 0 或 3" placeholder-class="field-placeholder" value="{{winMarginBalls}}" data-field="winMarginBalls" bindinput="onInput" />
          </view>

          <block wx:else>
            <view wx:if="{{activeSport === 'TABLE_TENNIS'}}" class="sub-block">
              <view class="sub-title">局制</view>
              <view class="pill-tabs">
                <view class="pill-tab {{bestOf === 1 ? 'active' : ''}}" data-value="1" bindtap="onBestOfTap">1 局</view>
                <view class="pill-tab {{bestOf === 3 ? 'active' : ''}}" data-value="3" bindtap="onBestOfTap">3 局</view>
                <view class="pill-tab {{bestOf === 5 ? 'active' : ''}}" data-value="5" bindtap="onBestOfTap">5 局</view>
                <view class="pill-tab {{bestOf === 7 ? 'active' : ''}}" data-value="7" bindtap="onBestOfTap">7 局</view>
              </view>
            </view>

            <view wx:for="{{sets}}" wx:for-index="setIndex" wx:key="index" class="set-row">
              <view class="set-row-head">
                <text class="set-label">第 {{setIndex + 1}} 局</text>
                <view class="swap-score-btn" data-index="{{setIndex}}" bindtap="swapSetScore">交换</view>
              </view>
              <view class="score-entry-grid">
                <view class="score-side">
                  <view class="team-score-label">
                    <block wx:if="{{teamA.length > 0}}">
                      <text wx:for="{{teamA}}" wx:for-item="player" wx:for-index="playerIndex" wx:key="id">{{player.nickname}}{{playerIndex + 1 < teamA.length ? '、' : ''}}</text>
                    </block>
                    <text wx:else>我方</text>
                  </view>
                  <input class="score-input" type="number" cursor-spacing="24" placeholder="分数" placeholder-class="field-placeholder score-placeholder" data-index="{{setIndex}}" data-field="aScore" value="{{item.aScore}}" bindinput="onSetInput" />
                </view>
                <text class="colon">:</text>
                <view class="score-side">
                  <view class="team-score-label">
                    <block wx:if="{{teamB.length > 0}}">
                      <text wx:for="{{teamB}}" wx:for-item="player" wx:for-index="playerIndex" wx:key="id">{{player.nickname}}{{playerIndex + 1 < teamB.length ? '、' : ''}}</text>
                    </block>
                    <text wx:else>对方</text>
                  </view>
                  <input class="score-input" type="number" cursor-spacing="24" placeholder="分数" placeholder-class="field-placeholder score-placeholder" data-index="{{setIndex}}" data-field="bScore" value="{{item.bScore}}" bindinput="onSetInput" />
                </view>
              </view>
              <view class="quick-score-row">
                <view
                  wx:for="{{quickScoreOptions}}"
                  wx:for-item="scoreOption"
                  wx:key="label"
                  class="quick-score-chip"
                  data-index="{{setIndex}}"
                  data-a-score="{{scoreOption.aScore}}"
                  data-b-score="{{scoreOption.bScore}}"
                  bindtap="applyQuickScore"
                >{{scoreOption.label}}</view>
              </view>
            </view>

            <view class="set-actions">
              <button class="button-ghost mini-btn" size="mini" bindtap="addSet">加一局</button>
              <button class="button-ghost mini-btn" size="mini" bindtap="removeSet">减一局</button>
            </view>
            <view wx:if="{{scorePreview}}" class="score-preview">{{scorePreview}}</view>
          </block>

          <view class="field">
            <view class="label">备注</view>
            <textarea class="textarea" placeholder="补充亮点、赛况等（选填）" placeholder-class="field-placeholder textarea-placeholder" value="{{remark}}" data-field="remark" bindinput="onInput" />
          </view>
        </view>
      </scroll-view>

      <view class="create-sheet-footer">
        <button class="button-ghost footer-btn" bindtap="closeCreateOverlay">取消</button>
        <button class="button-primary footer-btn footer-submit" loading="{{saving}}" bindtap="submitMatch">提交并发起确认</button>
      </view>
    </view>
  </view>
</view>
