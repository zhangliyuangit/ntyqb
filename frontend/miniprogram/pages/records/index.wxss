.record-page {
  position: relative;
}

.auth-gate-card {
  background:
    radial-gradient(circle at top right, rgba(7, 193, 96, 0.14), transparent 36%),
    linear-gradient(160deg, #ffffff 0%, #f4faf6 100%);
}

.gate-copy {
  margin-top: 14rpx;
  color: #6f7d8c;
  font-size: 24rpx;
  line-height: 1.7;
}

.gate-feature-list {
  margin-top: 24rpx;
}

.gate-feature {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(229, 235, 241, 0.92);
  color: #16212f;
  font-size: 24rpx;
}

.gate-feature + .gate-feature {
  margin-top: 12rpx;
}

.gate-login-btn {
  margin-top: 26rpx;
}

.workflow-strip {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.workflow-step {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(237, 241, 245, 0.95);
  color: #7f8b99;
  font-size: 22rpx;
  font-weight: 600;
}

.workflow-step.ready {
  background: rgba(7, 193, 96, 0.12);
  color: #0f8e4a;
}

.step-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(229, 235, 241, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.04);
}

.filter-card {
  margin-bottom: 24rpx;
}

.filter-tip {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(7, 193, 96, 0.08);
  color: #0f8e4a;
  font-size: 24rpx;
  line-height: 1.6;
}

.step-head,
.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.step-index {
  color: #0f8e4a;
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.step-note {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f6f8;
  color: #6c7987;
  font-size: 22rpx;
}

.list-toolbar {
  padding: 8rpx 4rpx 0;
}

.list-toolbar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #16212f;
}

.status-tabs {
  margin-bottom: 0;
}

.helper {
  color: #7f8b99;
  font-size: 23rpx;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.sub-block {
  margin-top: 20rpx;
}

.sub-title {
  margin-bottom: 14rpx;
  font-size: 25rpx;
  font-weight: 600;
}

.versus-picker {
  display: flex;
  align-items: stretch;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.side-panel {
  flex: 1;
  min-width: 0;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f7faf8;
  border: 1rpx solid rgba(220, 232, 224, 0.95);
}

.side-panel.opponent {
  background: #f8fafc;
  border-color: rgba(222, 229, 238, 0.95);
}

.side-title {
  margin-bottom: 12rpx;
  color: #516272;
  font-size: 22rpx;
  font-weight: 700;
}

.side-slots {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-height: 86rpx;
}

.versus-mark {
  width: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a95a2;
  font-size: 20rpx;
  font-weight: 800;
}

.player-pill {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(226, 234, 241, 0.95);
}

.player-pill-avatar {
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
}

.player-pill-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.player-pill-name {
  min-width: 0;
  color: #16212f;
  font-size: 24rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-pill-remove {
  flex-shrink: 0;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #f1f4f7;
  color: #708090;
  font-size: 26rpx;
  line-height: 32rpx;
  text-align: center;
}

.empty-slot {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  border: 1rpx dashed rgba(184, 197, 210, 0.9);
  color: #8a95a2;
  font-size: 23rpx;
}

.search-box,
.player-search-box {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.search-input,
.input {
  flex: 1;
  min-height: 76rpx;
  background: #f7f9fc;
  border-radius: 18rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(228, 234, 240, 0.95);
  font-size: 26rpx;
  color: #16212f;
}

.search-btn {
  margin: 0;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 28rpx;
}

.player-search-action {
  flex-shrink: 0;
  min-width: 116rpx;
  height: 76rpx;
  border-radius: 18rpx;
  background: #16212f;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
}

.player-results {
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(229, 235, 241, 0.95);
}

.player-results-head {
  padding: 18rpx 20rpx 12rpx;
  color: #617080;
  font-size: 22rpx;
  font-weight: 700;
}

.player-results-scroll {
  width: 100%;
  white-space: nowrap;
}

.player-card-track {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 20rpx 20rpx;
}

.player-row {
  width: 220rpx;
  min-height: 210rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(229, 235, 241, 0.95);
}

.player-row-avatar {
  flex-shrink: 0;
  width: 62rpx;
  height: 62rpx;
  border-radius: 18rpx;
}

.player-row-main {
  width: 100%;
  min-width: 0;
}

.player-row-name {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
  color: #16212f;
  font-size: 25rpx;
  font-weight: 700;
  white-space: normal;
}

.player-row-meta {
  display: block;
  margin-top: 6rpx;
  color: #8a95a2;
  font-size: 21rpx;
  white-space: normal;
}

.player-row-action {
  flex-shrink: 0;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.1);
  color: #0f8e4a;
  font-size: 22rpx;
  font-weight: 700;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #617080;
  font-size: 23rpx;
}

.textarea {
  width: 100%;
  min-height: 168rpx;
  background: #f7f9fc;
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(228, 234, 240, 0.95);
  font-size: 26rpx;
  color: #16212f;
  line-height: 1.6;
}

.set-row {
  margin-bottom: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #f9fbfd;
  border: 1rpx solid rgba(231, 236, 242, 0.9);
}

.set-row-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.set-label {
  color: #617080;
  font-size: 23rpx;
}

.swap-score-btn {
  min-width: 96rpx;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(216, 225, 235, 0.95);
  color: #476077;
  font-size: 22rpx;
  line-height: 48rpx;
  text-align: center;
}

.score-entry-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 28rpx minmax(0, 1fr);
  align-items: end;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.score-side {
  min-width: 0;
}

.team-score-label {
  min-height: 34rpx;
  margin-bottom: 8rpx;
  color: #253447;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.score-input {
  width: 100%;
  min-height: 72rpx;
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  border: 1rpx solid rgba(228, 234, 240, 0.95);
  font-size: 26rpx;
  color: #16212f;
}

.colon {
  color: #7f8b99;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 72rpx;
  text-align: center;
}

.quick-score-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.quick-score-chip {
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid rgba(216, 225, 235, 0.95);
  color: #34475b;
  font-size: 22rpx;
  line-height: 48rpx;
}

.set-actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.mini-btn {
  margin: 0;
}

.score-preview {
  margin: -4rpx 0 20rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #f5f8fb;
  color: #34475b;
  font-size: 23rpx;
  line-height: 1.45;
}

.field-placeholder {
  font-size: 22rpx;
  color: #a0acb8;
}

.score-placeholder {
  text-align: center;
}

.textarea-placeholder {
  line-height: 1.6;
}

.create-overlay {
  position: fixed;
  inset: 0;
  z-index: 1200;
}

.create-overlay-mask {
  position: absolute;
  inset: 0;
  background: rgba(16, 24, 38, 0.26);
}

.create-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 88vh;
  max-height: 92vh;
  border-radius: 36rpx 36rpx 0 0;
  background: linear-gradient(180deg, #f9fcfa 0%, #f5f7f8 100%);
  box-shadow: 0 -18rpx 48rpx rgba(16, 24, 38, 0.12);
  display: flex;
  flex-direction: column;
}

.create-sheet-handle {
  width: 96rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(120, 129, 144, 0.32);
  margin: 18rpx auto 0;
}

.create-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 26rpx 18rpx;
}

.sheet-close {
  min-width: 104rpx;
  text-align: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(240, 244, 247, 0.96);
  color: #5f6d7c;
  font-size: 23rpx;
}

.create-sheet-body {
  flex: 1;
  min-height: 0;
  padding: 4rpx 24rpx 0;
  box-sizing: border-box;
}

.sheet-tail-space {
  margin-bottom: 12rpx;
}

.create-sheet-footer {
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid rgba(229, 235, 241, 0.96);
}

.footer-btn {
  flex: 1;
  min-height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  font-size: 25rpx;
  font-weight: 600;
}

.footer-submit {
  box-shadow: 0 12rpx 22rpx rgba(7, 193, 96, 0.16);
}
