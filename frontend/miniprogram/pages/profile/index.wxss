.profile-card {
  background:
    radial-gradient(circle at top right, rgba(7, 193, 96, 0.14), transparent 36%),
    linear-gradient(155deg, #ffffff 0%, #eef8f1 100%);
}

.profile-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  border: 6rpx solid rgba(7, 193, 96, 0.12);
}

.name {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.meta {
  color: #7f8b99;
  font-size: 24rpx;
}

.logout-btn {
  margin: 0;
}

.profile-note {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.7);
  font-size: 23rpx;
  line-height: 1.7;
  color: #647484;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-toggle {
  color: #07c160;
  font-size: 24rpx;
  font-weight: 600;
}

.stats-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.fold-note {
  padding: 22rpx 24rpx;
  color: #7b8794;
  font-size: 23rpx;
}
