.auth-page {
  min-height: 100vh;
  padding: 40rpx 28rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(7, 193, 96, 0.14), transparent 34%),
    linear-gradient(180deg, #f7fbf8 0%, #eef3f0 100%);
}

.brand-panel {
  padding: 24rpx 8rpx 34rpx;
}

.brand-mark {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.brand-ball {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
}

.ball-one {
  background: #07c160;
}

.ball-two {
  background: #ffc939;
}

.ball-three {
  background: #0f172a;
}

.brand-title {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #102031;
}

.brand-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #667585;
}

.auth-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 24rpx 60rpx rgba(16, 32, 49, 0.08);
  backdrop-filter: blur(16rpx);
}

.auth-head {
  margin-bottom: 26rpx;
}

.auth-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #102031;
}

.auth-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f7d8c;
}

.avatar-picker {
  width: 100%;
  padding: 0;
  background: transparent;
  border: none;
}

.avatar-picker::after {
  border: none;
}

.avatar-image,
.avatar-empty {
  width: 168rpx;
  height: 168rpx;
  border-radius: 38rpx;
  margin: 0 auto;
}

.avatar-image {
  display: block;
  border: 8rpx solid rgba(7, 193, 96, 0.12);
}

.avatar-empty {
  background: linear-gradient(145deg, #f2fbf6 0%, #ebf4ef 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #07c160;
}

.avatar-empty-title {
  font-size: 28rpx;
  font-weight: 600;
}

.avatar-empty-sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7d8a97;
}

.field-block {
  margin-top: 30rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #6f7d8c;
}

.nickname-input {
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f5f7fa;
  box-sizing: border-box;
}

.saved-profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f5f7fa;
}

.saved-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
}

.saved-copy {
  flex: 1;
}

.saved-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #102031;
}

.saved-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6f7d8c;
}

.error-panel {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff3f2;
  color: #d94d46;
  font-size: 24rpx;
}

.auth-button {
  width: 100%;
  margin-top: 28rpx;
  height: 76rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-button-text {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
}

.reset-button {
  width: 100%;
  margin-top: 14rpx;
}

.browse-button {
  width: 100%;
  margin-top: 14rpx;
}
