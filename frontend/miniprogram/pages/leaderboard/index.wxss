.board-hero {
  background:
    radial-gradient(circle at top right, rgba(7, 193, 96, 0.16), transparent 36%),
    linear-gradient(160deg, #ffffff 0%, #f1faf5 100%);
  border-radius: 34rpx;
  padding: 32rpx 30rpx;
  border: 1rpx solid rgba(223, 236, 228, 0.92);
}

.board-hero-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #16212f;
}

.board-hero-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6d7887;
}

.board-hero-meta {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.board-meta-block {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.76);
}

.board-meta-value {
  display: block;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 700;
  color: #16212f;
}

.board-meta-label {
  display: block;
  margin-top: 10rpx;
  color: #71808e;
  font-size: 22rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.board-section-head {
  margin-bottom: 20rpx;
}

.rank {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(160deg, #e9f9ef 0%, #d9f4e5 100%);
  color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.podium-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.podium-card {
  display: grid;
  grid-template-columns: 92rpx 92rpx 1fr auto;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 24rpx 24rpx 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, #ffffff 0%, #f4faf6 100%);
  border: 1rpx solid rgba(223, 236, 228, 0.95);
}

.podium-card.rank-1 {
  background: linear-gradient(160deg, #fefcf3 0%, #f4faef 100%);
}

.podium-card.rank-2 {
  background: linear-gradient(160deg, #fbfcfd 0%, #f4f7fb 100%);
}

.podium-card.rank-3 {
  background: linear-gradient(160deg, #fff8f1 0%, #f7fbf7 100%);
}

.podium-rank {
  color: #0f8e4a;
  font-size: 24rpx;
  font-weight: 700;
}

.podium-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
}

.podium-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #16212f;
}

.podium-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.podium-meta {
  margin-top: 8rpx;
  color: #6d7887;
  font-size: 24rpx;
}

.podium-points {
  color: #16212f;
  font-size: 32rpx;
  font-weight: 700;
}

.board-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(230, 236, 242, 0.92);
}

.board-row.muted {
  background: rgba(252, 253, 254, 0.8);
}

.muted-rank {
  background: #eef2f5;
  color: #8d98a7;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
}

.profile {
  flex: 1;
}

.name {
  font-weight: 600;
  margin-bottom: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #6d7887;
}

.score {
  text-align: right;
}

.score-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.score-label {
  display: block;
  font-size: 22rpx;
  color: #7f8b99;
}

.provisional-shell {
  padding-top: 6rpx;
}
