.notice {
  background:
    radial-gradient(circle at top right, rgba(7, 193, 96, 0.12), transparent 38%),
    linear-gradient(155deg, #ffffff 0%, #f5fbf7 100%);
  border-radius: 28rpx;
  padding: 28rpx 30rpx;
  border: 1rpx solid rgba(223, 236, 228, 0.9);
}

.notice-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.notice-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #0d8c4a;
  font-size: 22rpx;
  font-weight: 600;
}

.notice-meta {
  color: #7c8896;
  font-size: 22rpx;
}

.notice-text {
  font-size: 35rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #16212f;
}

.home-stats-head {
  margin-bottom: 14rpx;
}

.home-stats-tabs {
  margin-bottom: 20rpx;
}

.home-stats-empty {
  min-height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #f6f8fa;
  color: #7b8794;
  font-size: 24rpx;
}

.error-title {
  font-weight: 700;
  margin-bottom: 12rpx;
}

.error-desc {
  margin-bottom: 24rpx;
  color: #7f8b99;
}

.retry-btn {
  width: 100%;
}

.feed-head {
  align-items: center;
}

.feed-count {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef3f6;
  color: #617080;
  font-size: 22rpx;
  font-weight: 600;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}
