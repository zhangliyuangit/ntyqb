.sport-card {
  background: linear-gradient(160deg, #ffffff 0%, #f8fffb 100%);
  border-radius: 24rpx;
  padding: 24rpx 22rpx;
  box-shadow: 0 12rpx 28rpx rgba(7, 193, 96, 0.06);
  border: 1rpx solid rgba(223, 236, 228, 0.82);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.title {
  font-size: 28rpx;
  font-weight: 600;
  color: #16212f;
}

.rate {
  color: #07c160;
  font-weight: 700;
  font-size: 34rpx;
}

.matches {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7f8b99;
}

.record-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.record-main {
  color: #16212f;
  font-size: 28rpx;
  font-weight: 600;
}

.record-note {
  color: #627080;
  font-size: 22rpx;
}

.rate-track {
  width: 100%;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.1);
  overflow: hidden;
}

.rate-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, #07c160 0%, #16a85f 100%);
}

.meta-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(231, 236, 240, 0.9);
}

.meta-row:first-child {
  padding-top: 0;
  border-top: none;
}

.meta-label {
  color: #7f8b99;
  font-size: 22rpx;
}

.meta-value {
  color: #16212f;
  font-size: 24rpx;
  font-weight: 600;
}
