.sport-card {
  background: linear-gradient(160deg, #ffffff 0%, #f8fffb 100%);
  border-radius: 22rpx;
  padding: 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.08);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.title {
  font-size: 28rpx;
  font-weight: 600;
  color: #16212f;
}

.rate {
  color: #07c160;
  font-weight: 700;
  font-size: 34rpx;
}

.matches {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7f8b99;
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.metric {
  background: #f6f8fb;
  border-radius: 16rpx;
  padding: 14rpx 10rpx;
  text-align: center;
}

.metric-value {
  display: block;
  font-weight: 700;
  font-size: 28rpx;
  color: #16212f;
}

.metric-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7f8b99;
}

.footer {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #607080;
}
