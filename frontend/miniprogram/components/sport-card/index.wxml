<view class="sport-card tone-{{rateTone}}">
  <view class="header">
    <view>
      <text class="title">{{title}}</text>
      <view class="matches">{{stat.matches}} 场已确认</view>
    </view>
    <text class="rate-label">{{rateLabel}}</text>
  </view>

  <view class="rate-panel">
    <view class="rate-stack">
      <text class="rate">{{rateText}}</text>
      <text class="rate-caption">胜率</text>
    </view>
    <view class="record-stack">
      <view class="record-main">{{stat.wins}} 胜 {{stat.losses}} 负</view>
      <view class="record-note">当前连胜 {{stat.streak}}</view>
    </view>
  </view>

  <view class="meta-grid">
    <view class="meta-item">
      <text class="meta-label">积分</text>
      <text class="meta-value">{{stat.rankingPoints}}</text>
    </view>
    <view class="meta-item">
      <text class="meta-label">近 10 胜</text>
      <text class="meta-value">{{stat.recentTenWins}}</text>
    </view>
  </view>
</view>
