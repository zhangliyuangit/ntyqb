<view class="sport-card">
  <view class="header">
    <view>
      <text class="title">{{title}}</text>
      <view class="matches">{{stat.matches}} 场已生效比赛</view>
    </view>
    <text class="rate">{{rateText}}</text>
  </view>
  <view class="record-line">
    <text class="record-main">{{stat.wins}} 胜 {{stat.losses}} 负</text>
    <text class="record-note">连胜 {{stat.streak}}</text>
  </view>
  <view class="rate-track">
    <view class="rate-fill" style="width: {{rateText}}"></view>
  </view>
  <view class="meta-list">
    <view class="meta-row">
      <text class="meta-label">积分</text>
      <text class="meta-value">{{stat.rankingPoints}}</text>
    </view>
    <view class="meta-row">
      <text class="meta-label">净胜</text>
      <text class="meta-value">{{stat.netValue}}</text>
    </view>
    <view class="meta-row">
      <text class="meta-label">最近 10 场胜</text>
      <text class="meta-value">{{stat.recentTenWins}}</text>
    </view>
  </view>
</view>
