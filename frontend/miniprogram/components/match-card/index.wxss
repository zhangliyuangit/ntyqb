.match-card {
  background: #ffffff;
  border-radius: 26rpx;
  padding: 24rpx 24rpx 22rpx;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.045);
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(228, 235, 242, 0.9);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.sport {
  font-weight: 700;
  font-size: 30rpx;
  color: #16212f;
}

.format {
  font-size: 21rpx;
  color: #607080;
  background: #f2f5f8;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.versus {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(236, 240, 244, 0.95);
  border-bottom: 1rpx solid rgba(236, 240, 244, 0.95);
}

.team-block {
  min-width: 0;
}

.team-a {
  text-align: left;
}

.team-b {
  text-align: right;
}

.versus-divider {
  padding: 10rpx 12rpx;
  border-radius: 999rpx;
  background: #f2f6f8;
  color: #7f8b99;
  font-size: 20rpx;
  font-weight: 700;
}

.team-label {
  color: #5d6b79;
  font-size: 22rpx;
  font-weight: 600;
  display: block;
}

.team-text {
  display: block;
  margin-top: 10rpx;
  color: #16212f;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 600;
  word-break: break-all;
}

.result-row {
  display: grid;
  grid-template-columns: 1.1fr 1fr auto;
  gap: 12rpx;
  margin-top: 16rpx;
}

.result-block,
.meta-inline {
  min-width: 0;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
}

.result-block {
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.12) 0%, rgba(7, 193, 96, 0.05) 100%);
}

.meta-label {
  display: block;
  margin-bottom: 8rpx;
  color: #7f8b99;
  font-size: 21rpx;
}

.meta-value {
  display: block;
  color: #16212f;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
  word-break: break-all;
}

.result-value {
  display: block;
  color: #11814a;
  font-size: 24rpx;
  font-weight: 700;
}

.meta-value.subtle {
  color: #617080;
  font-weight: 500;
}

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 18rpx;
}

.action-btn {
  margin: 0;
  min-width: 108rpx;
}

.match-card.compact {
  padding: 20rpx 20rpx 18rpx;
  border-radius: 22rpx;
  margin-bottom: 16rpx;
}

.match-card.compact .header {
  margin-bottom: 14rpx;
}

.match-card.compact .sport {
  font-size: 27rpx;
}

.match-card.compact .format {
  font-size: 20rpx;
  padding: 6rpx 12rpx;
}

.match-card.compact .versus {
  gap: 14rpx;
  padding: 16rpx 0;
}

.match-card.compact .team-label {
  font-size: 20rpx;
}

.match-card.compact .team-text {
  margin-top: 8rpx;
  font-size: 23rpx;
}

.match-card.compact .result-row {
  margin-top: 14rpx;
  gap: 10rpx;
}

.match-card.compact .result-block,
.match-card.compact .meta-inline {
  padding: 14rpx 16rpx;
}

.match-card.compact .meta-label {
  margin-bottom: 6rpx;
  font-size: 20rpx;
}

.match-card.compact .meta-value,
.match-card.compact .result-value {
  font-size: 22rpx;
}

.match-card.compact .actions {
  margin-top: 14rpx;
}
