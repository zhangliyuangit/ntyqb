:root {
  --page-bg: #f4f6f8;
  --card-bg: #ffffff;
  --text-main: #16212f;
  --text-sub: #7f8b99;
  --line: #e7ebf0;
  --brand: #07c160;
  --brand-soft: #e9f9ef;
  --warning: #ff9f0a;
  --danger: #ee5a52;
  --shadow: 0 10rpx 30rpx rgba(22, 33, 47, 0.06);
  --radius-lg: 24rpx;
  --radius-md: 18rpx;
  --radius-sm: 12rpx;
}

page {
  background: linear-gradient(180deg, #f7faf8 0%, #f3f5f8 180rpx, #f4f6f8 100%);
  color: var(--text-main);
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  padding: 28rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.section-subtitle {
  color: var(--text-sub);
  font-size: 24rpx;
}

.pill-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.pill-tab {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #edf1f5;
  color: var(--text-sub);
  font-size: 23rpx;
}

.pill-tab.active {
  background: var(--brand-soft);
  color: var(--brand);
  font-weight: 600;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.tag.success {
  background: #e8f9ee;
  color: #05984a;
}

.tag.pending {
  background: #fff4e0;
  color: #d47a00;
}

.tag.danger {
  background: #ffeceb;
  color: #d9423c;
}

.tag.muted {
  background: #eef2f5;
  color: #7f8b99;
}

.empty {
  padding: 48rpx 24rpx;
  text-align: center;
  color: var(--text-sub);
}

.button-primary {
  background: linear-gradient(135deg, #07c160 0%, #06b258 100%);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 24rpx;
  border: none;
  box-shadow: 0 8rpx 16rpx rgba(7, 193, 96, 0.12);
  font-weight: 600;
}

.button-ghost {
  background: #f2f5f7;
  color: var(--text-main);
  border-radius: 999rpx;
  border: none;
  font-size: 23rpx;
}

.button-primary::after,
.button-ghost::after,
.button-warn::after {
  border: none;
}

button.button-primary {
  background: linear-gradient(135deg, #07c160 0%, #06b258 100%);
  color: #ffffff;
}

button.button-primary[disabled],
button.button-primary[loading] {
  background: #33c774;
  color: rgba(255, 255, 255, 0.98);
  box-shadow: none;
  opacity: 1;
}

.placeholder-avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #e5f7ec 0%, #dff4e7 100%);
  color: #07c160;
  font-weight: 700;
}

.small-avatar {
  font-size: 20rpx;
}

.button-warn {
  background: #fff2f1;
  color: var(--danger);
  border-radius: 999rpx;
  border: none;
  font-size: 23rpx;
}
